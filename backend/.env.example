# Copy this to .env and adjust values before running

HOST=0.0.0.0
PORT=8000
DEBUG=false

# Space-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# File limits (MB)
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500

# Model settings
YOLO_MODEL=yolov8n.pt   # yolov8s.pt / yolov8m.pt / yolov8l.pt for better accuracy
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
DEVICE=cpu              # cuda:0 for GPU

# Video frame-skip (process every Nth frame)
FRAME_SKIP=3

# Rate limiting
RATE_LIMIT_IMAGE=30/minute
RATE_LIMIT_VIDEO=5/minute

# Temp file cleanup TTL (seconds)
FILE_TTL_SECONDS=3600
